{
  "name": "pickmem-extension",
  "version": "0.1.0",
  "private": true,
  "description": "PickMem Chrome extension — pick memory items and inject into any web chat.",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types 'test/*.test.ts'",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  }
}
